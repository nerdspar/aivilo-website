# Copy to .env and fill in. Only needed if you run the cloudflared sidecar
# (docker compose --profile tunnel up -d).
#
# Get this token from Cloudflare Zero Trust:
#   Networks → Tunnels → (create/select a tunnel) → Docker → copy the value
#   after `--token` (a long "eyJ..." string).
CLOUDFLARE_TUNNEL_TOKEN=
